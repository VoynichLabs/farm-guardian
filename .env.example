# Farm Guardian — Environment Secrets
# Copy this to .env and fill in your real values.

# Camera credentials
CAMERA_PASSWORD=your_camera_password

# Discord webhook for alerts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# eBird API key (get from https://ebird.org/api/keygen)
EBIRD_API_KEY=your_ebird_api_key

# Cloudflare API token (cfat_ prefix — for managing tunnels via API)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Cloudflare Tunnel run token (base64 string — used by cloudflared to connect)
# Get this from: cloudflared tunnel token <tunnel-name>
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token
