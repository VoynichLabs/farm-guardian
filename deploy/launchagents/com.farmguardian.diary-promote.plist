<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.farmguardian.diary-promote</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/macmini/Documents/GitHub/farm-guardian/venv/bin/python</string>
        <string>/Users/macmini/Documents/GitHub/farm-guardian/scripts/diary-promote-on-reaction.py</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/macmini/Documents/GitHub/farm-guardian</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/macmini/.local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
    <!-- Hourly: catch the Boss's reaction on the prior night's diary post and
         publish it to /field-notes. Reactions aren't time-critical, so hourly is
         plenty. Per docs/23-Jul-2026-diary-visible-and-staleness-alarm-plan.md. -->
    <key>StartInterval</key>
    <integer>3600</integer>
    <key>StandardOutPath</key>
    <string>/tmp/diary-promote.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/diary-promote.err.log</string>
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
